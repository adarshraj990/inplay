{
  "name": "indplay-monorepo",
  "version": "1.0.0",
  "description": "Indplay - High-Performance Social Gaming App (Monorepo)",
  "private": true,
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=server",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "prisma:generate": "npm run prisma:generate --workspace=server",
    "prisma:migrate": "npm run prisma:migrate --workspace=server",
    "prisma:studio": "npm run prisma:studio --workspace=server"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": ["gaming", "social", "real-time", "monorepo", "indplay"],
  "author": "Indplay Team",
  "license": "MIT"
}
