{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "dom"],
    "allowJs": true,
    "jsx": "react-native",
    "noEmit": true,
    "isolatedModules": true,
    "strict": false,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "react-native": ["src/types/any_shim.ts"],
      "react-native-linear-gradient": ["src/types/any_shim.ts"],
      "react-native-agora": ["src/types/any_shim.ts"],
      "react-native-vector-icons/*": ["src/types/any_shim.ts"],
      "react-native-reanimated": ["src/types/any_shim.ts"],
      "@react-navigation/*": ["src/types/any_shim.ts"],
      "@react-native-async-storage/async-storage": ["src/types/any_shim.ts"],
      "better-auth/react": ["src/types/any_shim.ts"],
      "socket.io-client": ["src/types/any_shim.ts"],
      "react-native-safe-area-context": ["src/types/any_shim.ts"],
      "react-native-haptic-feedback": ["src/types/any_shim.ts"],
      "react-native-gesture-handler": ["src/types/any_shim.ts"],
      "@react-native-community/blur": ["src/types/any_shim.ts"],
      "csstype": ["src/types/csstype.d.ts"]
    },
    "types": ["react"],
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "index.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
