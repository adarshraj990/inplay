{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "dom"],
    "allowJs": true,
    "jsx": "react-native",
    "noEmit": true,
    "isolatedModules": true,
    "strict": false,
    "moduleResolution": "node",
    "baseUrl": ".",
    "typeRoots": [
      "./node_modules/@types",
      "./typings"
    ],
    "paths": {
      "src/*": ["src/*"],
      "csstype": ["src/types/csstype.d.ts"]
    },
    "types": ["react"],
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "index.ts",
    "typings/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
