{
  "name": "@indplay/server",
  "version": "1.0.0",
  "description": "Indplay Backend Server - Node.js + TypeScript + Socket.io",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate && npx prisma db push --accept-data-loss && tsc",
    "start": "node dist/index.js",
    "analyze": "tsc --noEmit && npm run lint",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "render-build": "npm install --legacy-peer-deps && npx prisma generate && npm run build"
  },
  "dependencies": {
    "@better-auth/infra": "^0.2.4",
    "@prisma/client": "^5.15.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "agora-access-token": "^2.0.4",
    "agora-token": "^2.0.5",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.6.5",
    "bull": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "eslint": "^8.56.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "prettier": "^3.1.1",
    "prisma": "^5.15.0",
    "redis": "^4.6.11",
    "reflect-metadata": "^0.2.1",
    "resend": "^6.12.0",
    "sharp": "^0.33.1",
    "socket.io": "^4.7.2",
    "supertest": "^6.3.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsyringe": "^4.8.0",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": "20.x"
  }
}
