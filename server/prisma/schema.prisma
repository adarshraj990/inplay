// This is your Prisma schema file — Indplay Social Gaming App
// Learn more about Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserStatus {
  ONLINE
  OFFLINE
  AWAY
  IN_GAME
  BUSY
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum RoomType {
  PUBLIC
  PRIVATE
  TOURNAMENT
}

enum MessageType {
  TEXT
  IMAGE
  GIF
  VOICE_NOTE
  SYSTEM
}

enum GameStatus {
  WAITING
  IN_PROGRESS
  FINISHED
  CANCELLED
}

// ── Models ────────────────────────────────────────────────────────────────────

model User {
  id             String     @id @default(uuid())
  gameUid        String     @unique
  username       String     @unique @db.VarChar(30)
  email          String     @unique
  passwordHash   String
  displayName    String?    @db.VarChar(50)
  avatarUrl      String?
  bio            String?    @db.VarChar(300)
  status         UserStatus @default(OFFLINE)
  level          Int        @default(1)
  xp             Int        @default(0)
  coins          Int        @default(0)
  dailyRewards   Json?
  lastDailyRewardAt DateTime?
  isVerified     Boolean    @default(false)
  lastSeenAt     DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // ── Relations ───────────────────────────────────
  sentFriendRequests     Friendship[]     @relation("FriendRequester")
  receivedFriendRequests Friendship[]     @relation("FriendAddressee")
  ownedRooms             Room[]           @relation("RoomOwner")
  roomMemberships        RoomMember[]
  sentMessages           Message[]
  gameSessions           GameParticipant[]
  notifications          Notification[]
  refreshTokens          RefreshToken[]
  achievements           UserAchievement[]
  blockedUsers           BlockedUser[]    @relation("Blocker")
  blockedByUsers         BlockedUser[]    @relation("Blocked")

  @@index([username])
  @@index([email])
  @@map("users")
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester   User             @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User             @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@map("friendships")
}

model BlockedUser {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("blocked_users")
}

model Room {
  id          String     @id @default(uuid())
  name        String     @db.VarChar(100)
  description String?    @db.VarChar(500)
  type        RoomType   @default(PUBLIC)
  coverUrl    String?
  maxMembers  Int        @default(50)
  ownerId     String
  isVoiceEnabled Boolean @default(true)
  passcode    String?
  tags        String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner       User       @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     RoomMember[]
  messages    Message[]
  gameSessions GameSession[]

  @@index([ownerId])
  @@index([type])
  @@map("rooms")
}

model RoomMember {
  id       String   @id @default(uuid())
  roomId   String
  userId   String
  role     String   @default("member") // member | moderator | admin
  joinedAt DateTime @default(now())

  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
  @@map("room_members")
}

model Message {
  id          String      @id @default(uuid())
  roomId      String
  senderId    String
  content     String?
  mediaUrl    String?
  type        MessageType @default(TEXT)
  replyToId   String?
  isEdited    Boolean     @default(false)
  isDeleted   Boolean     @default(false)
  reactions   Json?       // { emoji: userId[] }
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  room        Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender      User        @relation(fields: [senderId], references: [id])
  replyTo     Message?    @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[]   @relation("MessageReplies")

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model GameSession {
  id          String      @id @default(uuid())
  roomId      String?
  gameType    String      // "trivia" | "word_guess" | "drawing" | "tic_tac_toe" etc.
  status      GameStatus  @default(WAITING)
  config      Json?       // game-specific config
  state       Json?       // current game state (snapshotted)
  winnerId    String?
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime    @default(now())

  room        Room?       @relation(fields: [roomId], references: [id])
  participants GameParticipant[]

  @@index([roomId])
  @@index([gameType, status])
  @@map("game_sessions")
}

model GameParticipant {
  id            String      @id @default(uuid())
  gameSessionId String
  userId        String
  score         Int         @default(0)
  rank          Int?
  metadata      Json?
  joinedAt      DateTime    @default(now())

  gameSession   GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id])

  @@unique([gameSessionId, userId])
  @@map("game_participants")
}

model Achievement {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  iconUrl     String?
  xpReward    Int      @default(0)
  createdAt   DateTime @default(now())

  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // friend_request | room_invite | game_invite | achievement
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
